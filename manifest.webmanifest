{
  "name": "Apostack — Controle Financeiro",
  "short_name": "Apostack",
  "description": "Aplicativo de controle financeiro pessoal por categoria. Acompanhe receitas, despesas, metas e relatórios em um painel claro.",
  "lang": "pt-BR",
  "dir": "ltr",
  "start_url": "/?utm_source=pwa",
