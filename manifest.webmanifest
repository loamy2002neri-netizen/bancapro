  "id": "/?source=pwa",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui", "browser"],
  "orientation": "portrait",
  "theme_color": "#060d18",
  "background_color": "#060d18",
  "categories": ["finance", "productivity", "business"],
